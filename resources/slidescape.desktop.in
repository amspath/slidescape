#!/usr/bin/env xdg-open

[Desktop Entry]
Type=Application
Name=Slidescape
Icon=${CMAKE_RUNTIME_OUTPUT_DIRECTORY}/resources/icon/icon.svg
Exec="${CMAKE_RUNTIME_OUTPUT_DIRECTORY}/slidescape" %U
Comment=Whole-slide image viewer
Categories=Graphics;
MimeType=image/tiff;image/isyntax;x-scheme-handler/slidescore;
